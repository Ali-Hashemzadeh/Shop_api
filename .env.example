APP_NAME=Laravel
APP_ENV=local
APP_KEY=base64:TrDJuAE3NY1+69Ck+rmPZp44I0uJiUsCX0AYwoEhGC4=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
 DB_HOST=127.0.0.1
 DB_PORT=3306
 DB_DATABASE=Shop_api
 DB_USERNAME=root
 DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
# options = ["email", "phone", "both"]
AUTH_LOGIN_FIELD=phone

# Passwordless OTP login
OTP_LENGTH=5
OTP_TTL_MINUTES=2

ADDRESS_REQUIRE_PROVINCE=true
ADDRESS_REQUIRE_CITY=true
ADDRESS_REQUIRE_POSTAL_CODE=false

# SMS.ir — template-based OTP delivery
# Leave SMSIR_API_KEY empty to fall back to log-only mode (dev/test)
SMSIR_API_KEY=
SMSIR_TEMPLATE_ID=

# Payment gateway
PAYMENT_DEFAULT_GATEWAY=zarinpal
ZARINPAL_MERCHANT_ID=
ZARINPAL_SANDBOX=false

# Frontend application — used to build navigation buttons on the backend-rendered
# payment result page (the gateway callback stays on the backend domain).
# Falls back to APP_URL when FRONTEND_URL is empty. Trailing slashes are normalized.
FRONTEND_URL=http://localhost:3000
# Path (relative to FRONTEND_URL) for a customer's order/tracking page.
# Result: {FRONTEND_URL}/{FRONTEND_ORDER_PATH}/{orderId}
FRONTEND_ORDER_PATH=orders

PUBLIC_STORAGE_PATH=

# Notification SMS — separate from the Identity OTP sender above.
# SMS_PROVIDER selects the active provider: smsir | log | fake
# (log = write to the log, no network I/O; fake = in-memory, tests only)
SMS_PROVIDER=log
SMS_SMSIR_API_KEY=
SMS_SMSIR_ENDPOINT=https://api.sms.ir/v1/send/verify

# Per-template ids at the provider. The keys in config/sms.php are our own
# provider-independent template names; these values are SMS.ir's ids.
SMS_SMSIR_PAYMENT_SUCCESS_TEMPLATE_ID=
SMS_SMSIR_ORDER_CANCELLED_TEMPLATE_ID=
SMS_SMSIR_SHIPMENT_PREPARING_TEMPLATE_ID=
SMS_SMSIR_SHIPMENT_SENT_TEMPLATE_ID=
SMS_SMSIR_SHIPMENT_DELIVERED_TEMPLATE_ID=

# Shipment — local-delivery service area (comma-separated numeric ids).
# An address matches if EITHER list contains it, so set cities alone (the common
# case), a province alone, or a province plus extra cities outside it.
# Leave BOTH empty to disable the restriction entirely: local delivery is then
# offered everywhere and post is never withdrawn.
# Inside the area the two postal methods are hidden and rejected at checkout;
# in-store pickup always stays available.
SHIPMENT_LOCAL_DELIVERY_PROVINCE_IDS=
SHIPMENT_LOCAL_DELIVERY_CITY_IDS=

# Shipment — method prices, in integer RIALS (no decimals, no separators).
# Omit a key to fall back to the default in config/shipment.php.
SHIPMENT_POST_STANDARD_PRICE=850000
SHIPMENT_POST_EXPRESS_PRICE=1400000
SHIPMENT_LOCAL_DELIVERY_PRICE=1200000
SHIPMENT_PICKUP_PRICE=0

# Shipment — in-store pickup location (shown for the in_person_pickup method)
SHIPMENT_PICKUP_TITLE="Main Store"
SHIPMENT_PICKUP_ADDRESS=
SHIPMENT_PICKUP_PHONE=

# Shipment — local-delivery slot generation (minutes/days; integers only)
SHIPMENT_SLOT_DURATION_MINUTES=90
SHIPMENT_SLOT_DEFAULT_CAPACITY=3
SHIPMENT_SLOT_GENERATION_DAYS=30
SHIPMENT_BOOKING_HORIZON_DAYS=14
SHIPMENT_MINIMUM_LEAD_MINUTES=60
SHIPMENT_MINIMUM_FINAL_SLOT_MINUTES=60

# Shipment — pending-order hold lifetime (keep in sync with the Order checkout TTL)
SHIPMENT_PENDING_ORDER_TTL_MINUTES=15
